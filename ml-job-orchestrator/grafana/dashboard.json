{
  "title": "ML Job Orchestrator",
  "uid": "mlorch-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Jobs Submitted Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(mlorch_jobs_submitted_total[1m])) by (job_type)",
          "legendFormat": "{{job_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "mlorch_queue_depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Success / Failure Ratio",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(mlorch_jobs_completed_total) / clamp_min(sum(mlorch_jobs_submitted_total), 1)",
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Job Duration Heatmap",
      "type": "heatmap",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(mlorch_job_duration_seconds_bucket[5m])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    }
  ]
}
